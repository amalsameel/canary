# copy this to `.env` or just run `canary setup` and let canary create it for you.
#
# required for online mode. get from ibm cloud → manage → access → api keys.
IBM_API_KEY=

# required for online mode. get from watsonx.ai → projects → manage.
IBM_PROJECT_ID=

# region endpoint. one of: us-south | eu-de | jp-tok | eu-gb | au-syd
IBM_REGION=us-south

# set to `true` to run granite locally via huggingface (no ibm account needed).
# requires: pip install transformers torch sentencepiece
# fast on apple silicon (m1/m2/m3) and nvidia gpus. slow on cpu-only machines.
IBM_LOCAL=false
